DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_here
DATABASE_PATH=data/jobs.db

INCLUDE_KEYWORDS=python,backend,software engineer,api,platform,automation
EXCLUDE_KEYWORDS=intern,internship,ios,android,frontend,react native
SCORING_ENABLED=true
SCORING_MIN_NOTIFY_SCORE=60
PREFERRED_KEYWORDS=python,backend,api,platform,data
PREFERRED_LOCATIONS=remote,mexico,mexico city
SENIORITY_PREFERENCE=senior

GREENHOUSE_ENABLED=true
GREENHOUSE_COMPANY_BOARDS=airbnb,shopify,stripe
GREENHOUSE_INCLUDE_CONTENT=true

# Optional / best-effort source using public Computrabajo search pages.
COMPUTRABAJO_ENABLED=true
COMPUTRABAJO_QUERY=python backend, ia engineer, software engineer
COMPUTRABAJO_LOCATION=Ciudad de Mexico
COMPUTRABAJO_REMOTE_ONLY=true

REQUEST_TIMEOUT_SECONDS=20
LOG_LEVEL=INFO
